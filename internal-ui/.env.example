# mainnet | testnet | devnet
VITE_NETWORK=mainnet

# Published yab package address (Move.toml [addresses] yab)
VITE_MODULE_ADDRESS=0xd42e699a4b22880d77da7dd02bb2fa768ecaa8cb1c4aa1423f968f480c97a60b

# Vault object address (pool state lives here)
VITE_VAULT_ADDRESS=0x599b04f9fc1c3702da76430d96a7962adbafd76941fe980d12e0bc0033f1379c

# Display / parse helpers (WBTC 8, USDC 6 on typical mainnet deployment)
VITE_TOKEN_A_DECIMALS=8
VITE_TOKEN_B_DECIMALS=6
# YAB metadata = vault object; default 8
# VITE_YAB_DECIMALS=8

# Hyperion indexer: `npm run dev` proxies /api/yieldai → yieldai.app (no CORS).
# Override target: VITE_HYPERION_PROXY_TARGET=https://yieldai.app
# Production static build: set VITE_HYPERION_USE_PROXY=true and reverse-proxy /api/yieldai on your host,
# or set full URL (direct, may hit CORS): VITE_HYPERION_USER_POSITIONS_URL=https://yieldai.app/api/protocols/hyperion/userPositions

# Optional — only if your fullnode/indexer provider requires an API key (e.g. Aptos Developer Portal)
# VITE_APTOS_API_KEY=
