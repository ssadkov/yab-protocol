# Copy to `.env` for local dev (`npm run dev` → http://localhost:5173)

# mainnet | testnet | devnet
VITE_NETWORK=mainnet

VITE_MODULE_ADDRESS=0xd42e699a4b22880d77da7dd02bb2fa768ecaa8cb1c4aa1423f968f480c97a60b
VITE_VAULT_ADDRESS=0x599b04f9fc1c3702da76430d96a7962adbafd76941fe980d12e0bc0033f1379c

VITE_TOKEN_A_DECIMALS=8
VITE_TOKEN_B_DECIMALS=6

# Optional: Aptos Developer Portal API key (mainnet indexer / rate limits)
# VITE_APTOS_API_KEY=

# Optional: proxy Hyperion indexer UI calls (`/api/yieldai/...`) — default https://yieldai.app
# VITE_HYPERION_PROXY_TARGET=https://yieldai.app
