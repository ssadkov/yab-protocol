## 3. Oracle Module (`oracle.move`)

Wrap Pyth with three mandatory guards. **Every price read in the protocol MUST go through `get_safe_price()` — never call Pyth directly.**

```move
module yab::oracle {
    use pyth::pyth;
    use pyth::price_identifier;
    use pyth::i64 as pyth_i64;
    use aptos_framework::timestamp;
    use yab::errors;

    // ── Parameters (governance-adjustable via VaultConfig) ────────────────
    const MAX_PRICE_AGE_SECS: u64 = 60;       // staleness threshold
    const MAX_DEVIATION_BPS:  u64 = 500;       // 5% max move per rebalance
    const MAX_CONF_BPS:       u64 = 100;       // 1% max Pyth confidence width

    // BTC/USD price feed ID on Aptos mainnet
    const BTC_USD_FEED: vector<u8> = x"e62df6c8b4a85fe1a67db44dc12de5db330f7ac66b72dc658afedf0f4a415b43";

    /// Returns BTC price in USD with 8 decimals. Aborts on any anomaly.
    public fun get_safe_price(last_recorded_price: u64): u64 {
        let feed_id = price_identifier::from_byte_vec(BTC_USD_FEED);
        let price_obj = pyth::get_price(feed_id);

        // Guard 1: staleness
        let age = timestamp::now_seconds() - pyth::get_price_timestamp(price_obj);
        assert!(age <= MAX_PRICE_AGE_SECS, errors::E_STALE_PRICE);

        let raw = pyth_i64::get_magnitude_if_positive(pyth::get_price_magnitude(price_obj));

        // Guard 2: deviation from last known price (skip if first call, i.e. last=0)
        if (last_recorded_price > 0) {
            let delta = if (raw > last_recorded_price) {
                (raw - last_recorded_price) * 10000 / last_recorded_price
            } else {
                (last_recorded_price - raw) * 10000 / last_recorded_price
            };
            assert!(delta <= MAX_DEVIATION_BPS, errors::E_PRICE_SPIKE);
        };

        // Guard 3: confidence interval
        let conf = pyth::get_price_conf(price_obj);
        let conf_ratio = conf * 10000 / raw;
        assert!(conf_ratio <= MAX_CONF_BPS, errors::E_LOW_CONFIDENCE);

        raw
    }
}
```

