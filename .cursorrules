## 4. Math Module (`math.move`)

Q64.64 sqrt price math for CLMM optimal split. Hyperion uses the same convention as Uniswap v3.

```move
module yab::math {
    /// Integer square root (babylonian)
    public fun sqrt_u128(x: u128): u128 {
        if (x == 0) return 0;
        let z = (x + 1) / 2;
        let y = x;
        while (z < y) { y = z; z = (x / z + z) / 2; };
        y
    }

    /// Compute optimal BTC fraction to add to position given current price position.
    /// All prices are sqrt prices in Q64.64 (multiply actual price by 2^64 before passing).
    /// Returns btc_ratio in BPS (0–10000).
    ///
    /// Formula: ratio = (sqrt_high - sqrt_current) / (sqrt_high - sqrt_low)
    public fun btc_ratio_bps(
        sqrt_current: u128,
        sqrt_low:     u128,
        sqrt_high:    u128,
    ): u64 {
        assert!(sqrt_current >= sqrt_low && sqrt_current <= sqrt_high, 0);
        let numerator   = (sqrt_high - sqrt_current) as u64;
        let denominator = (sqrt_high - sqrt_low)     as u64;
        if (denominator == 0) return 0;
        numerator * 10000 / denominator
    }

    /// Convert USD price (8 decimals) to Q64.64 sqrt price
    public fun price_to_sqrt_q64(price_usd: u64): u128 {
        // sqrt(price) * 2^64
        let p128 = (price_usd as u128);
        sqrt_u128(p128) << 32   // approximation — refine with Hyperion's exact formula
    }
}
```

