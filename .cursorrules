        // TODO: swap fee_usdc -> BTC with slippage guard:
        //       min_btc = fee_usdc * 1e8 * (10000 - slippage) / btc_price / 10000

        // 2. Claim gauge rewards (RION, etc.) — convert immediately, never hold
        // TODO: let rion_amount = hyperion::claim_gauge_rewards(state.position_id)
        // TODO: if rion_amount > RION_AUTO_CONVERT_THRESHOLD {
        //           let btc_from_rion = hyperion::swap_rion_to_btc(rion_amount, min_out)
        //           state.free_btc += btc_from_rion
        //       }
        // IMPORTANT: RION must NOT be added to NAV — convert or discard

        // 3. Add converted BTC to Free Reserves
        // state.free_btc += fee_btc_total;

        let btc_received: u64 = 0; // replace with actual total
        aptos_framework::event::emit(RewardsClaimed { btc_received, timestamp: timestamp::now_seconds() });
    }
```

### 6.7 Rebalance (Atomic — no pause)

```move
    /// Operator calls when price exits trigger band.
    /// Entire flow is one transaction — no MEV window, no deposit/withdraw pause.
    public entry fun rebalance(
        operator: &signer,
        vault_addr: address,
    ) acquires VaultState, VaultStrategy {
        let op_addr = signer::address_of(operator);
        let state   = borrow_global_mut<VaultState>(vault_addr);
        assert!(op_addr == state.operator || op_addr == state.admin, errors::E_NOT_OPERATOR);

        // 1. Time guard — prevent rebalance spam
        let strategy = borrow_global<VaultStrategy>(vault_addr);
        let now = timestamp::now_seconds();
        assert!(
            now >= state.last_rebalance_ts + strategy.params.min_rebalance_interval_secs,
            errors::E_REBALANCE_TOO_EARLY,
        );

        // 2. Oracle — circuit breaker applies
        let btc_price = oracle::get_safe_price(state.last_recorded_price);
        state.last_recorded_price = btc_price;

        // 3. Check if rebalance is actually needed
        assert!(
            strategy::should_rebalance(btc_price, state.center_price, &strategy.params),
            errors::E_REBALANCE_NOT_NEEDED,
        );

        // ── ATOMIC BLOCK START ────────────────────────────────────────────
        // Everything below is one transaction. Any abort = full rollback.

        // 4. Close existing Hyperion position, collect all fees
        // TODO: let (btc_from_pos, usdc_from_pos) = hyperion::close_position(state.position_id)
        // TODO: let (fee_btc, fee_usdc) = hyperion::collect_fees(state.position_id)
        //       merge into free reserves

        // 5. Convert all USDC to proportional BTC for new range
        let new_range = strategy::get_target_range(btc_price, &strategy.params);
        let btc_ratio = math::btc_ratio_bps(
            math::price_to_sqrt_q64(btc_price),
            new_range.sqrt_price_low,
            new_range.sqrt_price_high,
        );
        // total_btc_equiv = state.free_btc + state.free_usdc converted
        // btc_to_add = total_btc_equiv * btc_ratio / 10000
        // swap delta to achieve target ratio
        // min_out on every swap = oracle_price * amount * (10000 - max_slippage) / 10000

        // 6. Open new Hyperion position
        // TODO: let new_position_id = hyperion::open_position(btc_to_add, usdc_to_add, new_range)
        // state.position_id   = new_position_id
        // state.center_price  = btc_price
        // state.last_rebalance_ts = now
        // update state.free_btc / free_usdc with leftovers

        // ── ATOMIC BLOCK END ──────────────────────────────────────────────

        let old_center = state.center_price;
        state.center_price = btc_price;
        state.last_rebalance_ts = now;

        aptos_framework::event::emit(Rebalanced { old_center, new_center: btc_price, timestamp: now });
    }
```

### 6.8 Governance Functions

```move
    /// Transfer admin role (timelock must be enforced off-chain or via separate timelock module)
    public entry fun set_operator(admin: &signer, vault_addr: address, new_operator: address)
    acquires VaultState {
        let state = borrow_global_mut<VaultState>(vault_addr);
        assert!(signer::address_of(admin) == state.admin, errors::E_NOT_ADMIN);
        state.operator = new_operator;
    }

    public entry fun set_performance_fee(admin: &signer, vault_addr: address, fee_bps: u64)
    acquires VaultState {
        let state = borrow_global_mut<VaultState>(vault_addr);
        assert!(signer::address_of(admin) == state.admin, errors::E_NOT_ADMIN);
        assert!(fee_bps <= 2000, errors::E_FEE_TOO_HIGH); // max 20%
        state.performance_fee_bps = fee_bps;
    }

    public entry fun set_strategy_params(
        admin: &signer,
        vault_addr: address,
        range_half_width_bps: u64,
        rebalance_trigger_bps: u64,
        max_swap_slippage_bps: u64,
    ) acquires VaultState, VaultStrategy {
        let state = borrow_global<VaultState>(vault_addr);
        assert!(signer::address_of(admin) == state.admin, errors::E_NOT_ADMIN);
        assert!(range_half_width_bps >= 100, errors::E_RANGE_TOO_NARROW); // min ±1%
        let strategy = borrow_global_mut<VaultStrategy>(vault_addr);
        strategy.params.range_half_width_bps    = range_half_width_bps;
        strategy.params.rebalance_trigger_bps   = rebalance_trigger_bps;
        strategy.params.max_swap_slippage_bps   = max_swap_slippage_bps;
    }

    // View functions
    #[view] public fun get_yab_price_view(vault_addr: address): u64 acquires VaultState { ... }
    #[view] public fun get_total_assets_view(vault_addr: address): u64 acquires VaultState { ... }
    #[view] public fun get_vault_state(vault_addr: address): (u64, u64, u64, u64) acquires VaultState { ... }
} // end module
```

---

## 7. Hyperion Interface — Real Function Signatures

All functions are in the `hyperion-interface` package (`github.com/Hyperfluid/hyperfluid-interface`).
Import modules: `pool_v3`, `router_v3`, `position_v3`.

### Open position (empty, no liquidity yet)
```move
// module: pool_v3
public fun open_position(
    user:       &signer,
    token_a:    Object<Metadata>,   // WBTC metadata object
    token_b:    Object<Metadata>,   // USDC metadata object
    fee_tier:   u8,                 // fee tier of the pool
    tick_lower: u32,
    tick_upper: u32,
): Object<position_v3::Info>
```

### Add liquidity
```move
// module: pool_v3
public fun add_liquidity(
    user:            &signer,
    position:        Object<position_v3::Info>,
    liquidity_delta: u128,          // liquidity units to add
    fa_a:            FungibleAsset, // WBTC to deposit
    fa_b:            FungibleAsset, // USDC to deposit
): (u64, u64, FungibleAsset, FungibleAsset)
// returns: (actual_a_used, actual_b_used, leftover_fa_a, leftover_fa_b)
// leftover → state.free_btc / state.free_usdc
```

### Remove liquidity
```move
// module: pool_v3
public fun remove_liquidity(
    user:            &signer,
    position:        Object<position_v3::Info>,
    liquidity_delta: u128,
): (Option<FungibleAsset>, Option<FungibleAsset>)
// returns: (Option<btc_fa>, Option<usdc_fa>)
// to close fully: pass position's total liquidity as liquidity_delta
```

### Collect trading fees
```move
// module: pool_v3
public fun claim_fees(
    user:     &signer,
    position: Object<position_v3::Info>,
): (FungibleAsset, FungibleAsset)
// returns: (fee_btc_fa, fee_usdc_fa)
```

### Collect gauge rewards (RION etc.)
```move
// module: pool_v3
public fun claim_rewards(
    user:     &signer,
    position: Object<position_v3::Info>,
): vector<FungibleAsset>
// returns vector — iterate and convert each token to BTC immediately
// NEVER add reward tokens to NAV directly
```

### Swap (exact input)
```move
// module: router_v3
public entry fun exact_input_swap_entry(
    user:              &signer,
    fee_tier:          u8,
    amount_in:         u64,
    amount_out_min:    u64,         // slippage guard — MUST come from oracle
    sqrt_price_limit:  u128,        // x64 fixed-point price impact limit, 0 = no limit
    from_token:        Object<Metadata>,
    to_token:          Object<Metadata>,
    recipient:         address,
    _deadline:         u64
)
```

> **Slippage rule (mandatory on every swap):**
> ```
> amount_out_min = oracle_price * amount_in * (10000 - max_slippage_bps) / 10000
> ```
> Never use pool spot price — always Pyth oracle. This is the main MEV defence.

### Vault signer pattern
Hyperion functions take `user: &signer`. The vault contract must hold a `SignerCapability`
(from `aptos_framework::account::create_resource_account`) so it can pass its own signer
to Hyperion on behalf of all depositors. Store `SignerCapability` in `VaultState` at init.

```move
// in VaultState:
signer_cap: SignerCapability,

// usage inside vault functions:
let vault_signer = account::create_signer_with_capability(&state.signer_cap);
let position = pool_v3::open_position(&vault_signer, btc_meta, usdc_meta, fee_tier, tick_lower, tick_upper);
```

