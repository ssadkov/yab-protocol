## 5. Strategy Interface (`strategy.move`)

The strategy module is separated so v2 can accept external curator strategies without touching `vault.move`.

> **v1 scope boundary — Cursor must not exceed this:**
> - ONE strategy, ONE Hyperion CLMM pool, ONE price range at a time
> - Do NOT implement `vector<Allocation>`, multi-pool weights, sub-vaults, or withdrawal queues
> - Do NOT add lending protocol integrations
> - The interface below is intentionally minimal — vault calls only these three functions
> - Everything else is v2/v3 and will be added later via Move upgrade

```move
module yab::strategy {
    /// Describes a price range for a Hyperion CL position
    struct Range has copy, drop, store {
        tick_lower: i32,   // use aptos_std::i32 or define locally
        tick_upper: i32,
        sqrt_price_low:  u128,
        sqrt_price_high: u128,
    }

    struct StrategyParams has key {
        /// half-width of range in BPS of current price (e.g. 500 = ±5%)
        range_half_width_bps: u64,
        /// minimum blocks since last rebalance (anti-spam)
        min_rebalance_interval_secs: u64,
        /// deviation from center that triggers rebalance (BPS)
        rebalance_trigger_bps: u64,
        /// max slippage on internal swaps (BPS)
        max_swap_slippage_bps: u64,
        /// dust threshold: auto-reinvest Free Reserves if > X BPS of TVL
        dust_reinvest_threshold_bps: u64,
    }

    // ── Default strategy (conservative BTC/USDC ±5%) ─────────────────────

    public fun default_params(): StrategyParams {
        StrategyParams {
            range_half_width_bps:        500,    // ±5%
            min_rebalance_interval_secs: 1800,   // 30 min minimum
            rebalance_trigger_bps:       400,    // trigger at ±4% from center
            max_swap_slippage_bps:       30,     // 0.3% max slippage
            dust_reinvest_threshold_bps: 10,     // reinvest if > 0.1% TVL
        }
    }

    /// Compute target range centered on current price
    public fun get_target_range(
        current_price_usd: u64,
        params: &StrategyParams,
    ): Range {
        use yab::math;
        let half = (current_price_usd as u128) * (params.range_half_width_bps as u128) / 10000;
        let price_low  = (current_price_usd as u128) - half;
        let price_high = (current_price_usd as u128) + half;
        Range {
            tick_lower:       0,   // TODO: convert price_low to Hyperion tick
            tick_upper:       0,   // TODO: convert price_high to Hyperion tick
            sqrt_price_low:  math::price_to_sqrt_q64(price_low  as u64),
            sqrt_price_high: math::price_to_sqrt_q64(price_high as u64),
        }
    }

    /// True if current price is outside rebalance trigger band
    public fun should_rebalance(
        current_price: u64,
        center_price:  u64,
        params: &StrategyParams,
    ): bool {
        let deviation = if (current_price > center_price) {
            (current_price - center_price) * 10000 / center_price
        } else {
            (center_price - current_price) * 10000 / center_price
        };
        deviation >= params.rebalance_trigger_bps
    }
}
```

> **For Cursor:** The `tick_lower`/`tick_upper` conversion from price to Hyperion tick must use the same tick spacing as the target Hyperion pool. Check `HYPERION_PACKAGE_ADDR::pool::tick_spacing()` and implement `price_to_tick()` using `ln(price) / ln(1.0001)` with integer approximation.

