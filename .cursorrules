## 6. Vault Module (`vault.move`)

Core vault. YAB token is issued as a **Fungible Asset (FA standard)** — not legacy Coin. Use `aptos_framework::fungible_asset` and `primary_fungible_store`.

### 6.1 Structs

```move
module yab::vault {
    use std::signer;
    use std::option;
    use aptos_framework::object::{Self, Object, ConstructorRef};
    use aptos_framework::fungible_asset::{Self, MintRef, BurnRef, TransferRef, FungibleAsset, Metadata};
    use aptos_framework::primary_fungible_store;
    use aptos_framework::timestamp;
    use yab::oracle;
    use yab::strategy::{Self, StrategyParams, Range};
    use yab::math;
    use yab::errors;
    // TODO: use hyperion::clmm  (import your Hyperion package here)

    // ── FA Refs (stored at vault object) ──────────────────────────────────
    #[resource_group_member(group = aptos_framework::object::ObjectGroup)]
    struct YabRefs has key {
        mint_ref:     MintRef,
        burn_ref:     BurnRef,
        transfer_ref: TransferRef,
    }

    // ── Vault State ───────────────────────────────────────────────────────
    #[resource_group_member(group = aptos_framework::object::ObjectGroup)]
    struct VaultState has key {
        /// admin (multisig address)
        admin: address,
        /// operator (off-chain bot, can call rebalance/claim)
        operator: address,
        /// treasury (receives performance fee as YAB shares)
        treasury: address,

        // ── Hyperion position ─────────────────────────────────────────────
        position_id: u64,          // Hyperion NFT position ID (0 = no open position)
        position_btc:  u64,        // last known BTC in position (updated on every operation)
        position_usdc: u64,        // last known USDC in position

        // ── Free Reserves ─────────────────────────────────────────────────
        free_btc:  u64,
        free_usdc: u64,

        // ── Range tracking ────────────────────────────────────────────────
        center_price:         u64,  // price at last open/rebalance (USD, 8 dec)
        last_rebalance_ts:    u64,
        last_recorded_price:  u64,  // for oracle deviation guard

        // ── Fee ───────────────────────────────────────────────────────────
        performance_fee_bps: u64,   // default 1000 = 10%
    }

    // ── Per-user deposit checkpoint (for performance fee) ─────────────────
    struct UserCheckpoint has key {
        entry_price: u64,    // YAB price at deposit (BTC units, 8 dec precision)
    }

    // ── Strategy config ───────────────────────────────────────────────────
    #[resource_group_member(group = aptos_framework::object::ObjectGroup)]
    struct VaultStrategy has key {
        params: StrategyParams,
    }

    // ── Events ────────────────────────────────────────────────────────────
    #[event] struct Deposited     has drop, store { user: address, btc_in: u64,    shares_minted: u64 }
    #[event] struct Withdrawn     has drop, store { user: address, shares_burned: u64, btc_out: u64 }
    #[event] struct Rebalanced    has drop, store { old_center: u64, new_center: u64, timestamp: u64 }
    #[event] struct RewardsClaimed has drop, store { btc_received: u64, timestamp: u64 }
```

### 6.2 Initialization

```move
    /// Called once by deployer. Creates vault object + mints YAB FA metadata.
    public entry fun initialize(
        admin: &signer,
        treasury: address,
        operator: address,
    ) {
        let admin_addr = signer::address_of(admin);

        // Create named object — deterministic address, owned by module
        let constructor = object::create_named_object(admin, b"YAB_VAULT_V1");
        let vault_signer = object::generate_signer(&constructor);

        // Create YAB as Fungible Asset on this object
        primary_fungible_store::create_primary_store_enabled_fungible_asset(
            &constructor,
            option::none(),        // no max supply
            utf8(b"Yield AI Bitcoin"),
            utf8(b"YAB"),
            8,                     // 8 decimals (same as BTC)
            utf8(b""),             // icon uri — fill before mainnet
            utf8(b""),             // project uri
        );

        // Store refs for mint/burn
        move_to(&vault_signer, YabRefs {
            mint_ref:     fungible_asset::generate_mint_ref(&constructor),
            burn_ref:     fungible_asset::generate_burn_ref(&constructor),
            transfer_ref: fungible_asset::generate_transfer_ref(&constructor),
        });

        move_to(&vault_signer, VaultState {
            admin,
            operator,
            treasury,
            position_id:          0,
            position_btc:         0,
            position_usdc:        0,
            free_btc:             0,
            free_usdc:            0,
            center_price:         0,
            last_rebalance_ts:    0,
            last_recorded_price:  0,
            performance_fee_bps:  1000,  // 10%
        });

        move_to(&vault_signer, VaultStrategy {
            params: strategy::default_params(),
        });
    }
```

### 6.2.1 Bootstrap — первый депозит и открытие позиции

**Это особый случай.** После `initialize()` vault пустой:
- `yab_supply = 0`
- `position = none`
- `free_btc = 0`

Обычный `deposit()` не подходит для первого раза потому что нет открытой позиции в Hyperion — некуда добавлять ликвидность. Нужна отдельная функция `bootstrap()` которую вызывает только admin один раз.

```move
/// Called ONCE by admin after initialize() to seed the vault and open the first position.
/// This is the first YAB mint — admin becomes the first LP.
public entry fun bootstrap(
    admin:      &signer,
    vault_addr: address,
    btc_in:     u64,        // initial BTC seed amount
    tick_lower: u32,        // initial range lower tick
    tick_upper: u32,        // initial range upper tick
    fee_tier:   u8,         // Hyperion pool fee tier
) acquires VaultState, YabRefs, VaultStrategy {
    let admin_addr = signer::address_of(admin);
    let state = borrow_global_mut<VaultState>(vault_addr);

    // Only admin, only once
    assert!(admin_addr == state.admin,   errors::E_NOT_ADMIN);
    assert!(state.position_obj == @0x0,  errors::E_ALREADY_BOOTSTRAPPED); // add this error code

    // 1. Get oracle price — sets last_recorded_price baseline
    let btc_price = oracle::get_safe_price(0); // 0 = skip deviation check on first call
    state.last_recorded_price = btc_price;
    state.center_price        = btc_price;

    // 2. Pull BTC from admin
    let vault_signer = account::create_signer_with_capability(&state.signer_cap);
    let btc_fa = primary_fungible_store::withdraw(admin, btc_metadata(), btc_in);

    // 3. Compute optimal split for the given range
    let strategy = borrow_global<VaultStrategy>(vault_addr);
    let sqrt_current = math::price_to_sqrt_q64(btc_price);
    let sqrt_low     = math::price_to_sqrt_q64(tick_to_price(tick_lower));
    let sqrt_high    = math::price_to_sqrt_q64(tick_to_price(tick_upper));
    let btc_ratio    = math::btc_ratio_bps(sqrt_current, sqrt_low, sqrt_high);

    let btc_to_add  = btc_in * btc_ratio / 10000;
    let btc_to_swap = btc_in - btc_to_add;

    // 4. Swap btc_to_swap → USDC via Hyperion router
    //    min_out from oracle, not spot price
    let min_usdc = btc_to_swap * btc_price / 100_000_000
                   * (10000 - strategy.params.max_swap_slippage_bps) / 10000;
    router_v3::exact_input_swap_entry(
        &vault_signer, fee_tier,
        btc_to_swap, min_usdc, 0,
        btc_metadata(), usdc_metadata(),
        vault_addr, MAX_DEADLINE,
    );

    // 5. Open empty position in Hyperion
    let position = pool_v3::open_position(
        &vault_signer,
        btc_metadata(), usdc_metadata(),
        fee_tier, tick_lower, tick_upper,
    );

    // 6. Add liquidity — compute liquidity_delta from amounts
    //    Use Hyperion's liquidity math or compute off-chain and pass as argument
    let (actual_btc, actual_usdc, leftover_btc_fa, leftover_usdc_fa) =
        pool_v3::add_liquidity(&vault_signer, position, liquidity_delta, btc_fa, usdc_fa);

    // 7. Save position object address and update state
    state.position_obj  = object::object_address(&position);
    state.position_btc  = actual_btc;
    state.position_usdc = actual_usdc;
    state.free_btc      = fungible_asset::amount(&leftover_btc_fa);
    state.free_usdc     = fungible_asset::amount(&leftover_usdc_fa);
    // deposit leftover FAs into vault's primary store
    primary_fungible_store::deposit(vault_addr, leftover_btc_fa);
    primary_fungible_store::deposit(vault_addr, leftover_usdc_fa);

    // 8. Mint initial YAB shares to admin
    //    Initial price = 1 BTC per YAB (1e8 units)
    //    shares = btc_in / initial_price = btc_in (since price = 1.0)
    let initial_shares = btc_in; // 1:1 at bootstrap, 8 decimals match
    let refs = borrow_global<YabRefs>(vault_addr);
    let yab_fa = fungible_asset::mint(&refs.mint_ref, initial_shares);
    primary_fungible_store::deposit(admin_addr, yab_fa);

    // 9. Save admin's entry checkpoint
    move_to(admin, UserCheckpoint { entry_price: 100_000_000 }); // 1.0 BTC per YAB

    state.last_rebalance_ts = timestamp::now_seconds();
}
```

**Последовательность вызовов при запуске:**
```bash
# 1. Деплой
aptos move publish --profile admin

# 2. Инициализация vault (создаёт объект + FA метаданные YAB)
aptos move run --function-id <ADDR>::vault::initialize \
  --args address:<TREASURY> address:<OPERATOR>

# 3. Bootstrap — первый депозит, открытие позиции, первый минт YAB
aptos move run --function-id <ADDR>::vault::bootstrap \
  --args address:<VAULT_ADDR> u64:100000000 u32:<TICK_LOWER> u32:<TICK_UPPER> u8:<FEE_TIER>
#              ^ 1 BTC в satoshi-единицах (8 decimals)

# 4. Обычные пользователи — уже через deposit()
```

**Ключевые отличия bootstrap от deposit:**

| | `bootstrap()` | `deposit()` |
|---|---|---|
| Кто вызывает | только admin | любой пользователь |
| Позиция | создаёт новую | добавляет в существующую |
| NAV при расчёте | начальная цена 1.0 BTC | текущий NAV |
| Тики диапазона | задаёт явно | берёт из стратегии |
| Вызывается | один раз | многократно |

### 6.3 NAV Calculation

```move
    /// Total assets in BTC (8 decimals).
    /// NEVER use spot price from Hyperion pool — always oracle.
    fun get_total_assets(state: &VaultState, btc_price: u64): u64 {
        let pos_btc_equiv  = state.position_btc + state.position_usdc * 100_000_000 / btc_price;
        let free_btc_equiv = state.free_btc     + state.free_usdc     * 100_000_000 / btc_price;
        pos_btc_equiv + free_btc_equiv
        // NOTE: reward tokens (RION etc.) are NOT included — they are
        //       converted to BTC immediately on claim (see claim_rewards)
    }

    /// YAB price in BTC (8 decimals precision). Returns 0 if supply is 0.
    fun get_yab_price(state: &VaultState, vault_addr: address, btc_price: u64): u64 {
        let yab_metadata = object::address_to_object<Metadata>(vault_addr);
        let supply = fungible_asset::supply(yab_metadata);
        if (supply == 0) return 100_000_000; // initial price = 1 BTC per YAB (1e8)
        let total = get_total_assets(state, btc_price);
        total * 100_000_000 / (supply as u64)
    }
```

### 6.4 Deposit

```move
    public entry fun deposit(
        user:    &signer,
        btc_in:  u64,          // amount of BTC (FA) to deposit
        vault_addr: address,
    ) acquires VaultState, YabRefs, VaultStrategy {
        assert!(btc_in > 0, errors::E_ZERO_AMOUNT);
        let user_addr = signer::address_of(user);
        let state = borrow_global_mut<VaultState>(vault_addr);

        // 1. Oracle price — fixes NAV before any state change
        let btc_price = oracle::get_safe_price(state.last_recorded_price);
        state.last_recorded_price = btc_price;
        let yab_price = get_yab_price(state, vault_addr, btc_price);

        // 2. Pull BTC from user via primary FA store
        // TODO: primary_fungible_store::withdraw(user, btc_metadata, btc_in)
        //       Replace btc_metadata with the FA Object<Metadata> for WBTC on Aptos

        // 3. Use Free Reserves first, then new funds
        let available_btc  = state.free_btc  + btc_in;
        let available_usdc = state.free_usdc;

        // 4. Optimal split for current range
        let strategy = borrow_global<VaultStrategy>(vault_addr);
        let range = strategy::get_target_range(btc_price, &strategy.params);
        let btc_ratio = math::btc_ratio_bps(
            math::price_to_sqrt_q64(btc_price),
            range.sqrt_price_low,
            range.sqrt_price_high,
        );
        let btc_to_add  = available_btc * btc_ratio / 10000;
        let btc_to_swap = available_btc - btc_to_add;

        // 5. Swap excess BTC → USDC via Hyperion
        // TODO: let usdc_received = hyperion::swap_exact_input(btc_to_swap, min_out, ...)
        //       min_out = btc_to_swap * btc_price * (10000 - slippage_bps) / 10000 / 1e8
        let usdc_to_add = available_usdc; // + usdc_received (after swap)

        // 6. Add liquidity to Hyperion
        // TODO: hyperion::add_liquidity(state.position_id, btc_to_add, usdc_to_add, range)
        //       Update state.position_btc and state.position_usdc with actual amounts used

        // 7. Leftover → Free Reserves
        state.free_btc  = 0; // btc_to_add used from available_btc
        state.free_usdc = 0; // usdc_to_add used

        // 8. Mint YAB shares AFTER all state changes
        let shares = btc_in * 100_000_000 / yab_price;
        let refs = borrow_global<YabRefs>(vault_addr);
        let yab_fa = fungible_asset::mint(&refs.mint_ref, shares);
        primary_fungible_store::deposit(user_addr, yab_fa);

        // 9. Save entry checkpoint for performance fee
        if (!exists<UserCheckpoint>(user_addr)) {
            move_to(user, UserCheckpoint { entry_price: yab_price });
        } else {
            // weighted average entry price on top-up
            // simplified: update to current (conservative — user gets less fee credit)
            let checkpoint = borrow_global_mut<UserCheckpoint>(user_addr);
            checkpoint.entry_price = yab_price;
        };

        aptos_framework::event::emit(Deposited { user: user_addr, btc_in, shares_minted: shares });
    }
```

### 6.5 Withdraw

```move
    public entry fun withdraw(
        user:       &signer,
        shares_in:  u64,
        vault_addr: address,
    ) acquires VaultState, YabRefs, UserCheckpoint {
        assert!(shares_in > 0, errors::E_ZERO_AMOUNT);
        let user_addr = signer::address_of(user);
        let state = borrow_global_mut<VaultState>(vault_addr);

        let btc_price = oracle::get_safe_price(state.last_recorded_price);
        state.last_recorded_price = btc_price;
        let yab_price = get_yab_price(state, vault_addr, btc_price);

        // 1. How much BTC this user is owed
        let btc_owed = shares_in * yab_price / 100_000_000;

        // 2. Performance fee — only if user is in profit
        let fee_shares: u64 = 0;
        if (exists<UserCheckpoint>(user_addr)) {
            let checkpoint = borrow_global<UserCheckpoint>(user_addr);
            if (yab_price > checkpoint.entry_price) {
                let profit_per_share = yab_price - checkpoint.entry_price;
                let total_profit = profit_per_share * shares_in / 100_000_000;
                let fee_btc = total_profit * state.performance_fee_bps / 10000;
                fee_shares = fee_btc * 100_000_000 / yab_price;
                btc_owed = btc_owed - fee_btc;

                // Mint fee shares to treasury
                let refs = borrow_global<YabRefs>(vault_addr);
                let fee_fa = fungible_asset::mint(&refs.mint_ref, fee_shares);
                primary_fungible_store::deposit(state.treasury, fee_fa);
            }
        };

        // 3. Fulfill from Free Reserves first
        let btc_out = 0u64;
        if (state.free_btc >= btc_owed) {
            btc_out = btc_owed;
            state.free_btc = state.free_btc - btc_owed;
        } else {
            btc_out = state.free_btc;
            state.free_btc = 0;
            let remainder = btc_owed - btc_out;

            // 4. Close proportional part of Hyperion position
            // TODO: let (btc_from_pos, usdc_from_pos) = hyperion::remove_liquidity_proportional(
            //           state.position_id, remainder, get_total_assets(state, btc_price))
            // TODO: swap usdc_from_pos -> BTC, add to btc_out
        };

        // 5. Transfer BTC to user
        // TODO: primary_fungible_store::deposit(user_addr, btc_fa_asset)

        // 6. Burn YAB shares
        let refs = borrow_global<YabRefs>(vault_addr);
        let user_yab = primary_fungible_store::withdraw(
            user,
            object::address_to_object<Metadata>(vault_addr),
            shares_in
        );
        fungible_asset::burn(&refs.burn_ref, user_yab);

        aptos_framework::event::emit(Withdrawn { user: user_addr, shares_burned: shares_in, btc_out });
    }
```

### 6.6 Claim Rewards

```move
    /// Operator calls this off-chain to harvest Hyperion trading fees and
    /// any gauge rewards (RION etc.), converting everything to BTC.
    public entry fun claim_rewards(
        operator: &signer,
        vault_addr: address,
    ) acquires VaultState {
        let op_addr = signer::address_of(operator);
        let state   = borrow_global_mut<VaultState>(vault_addr);
        assert!(op_addr == state.operator || op_addr == state.admin, errors::E_NOT_OPERATOR);

        let btc_price = oracle::get_safe_price(state.last_recorded_price);
        state.last_recorded_price = btc_price;

